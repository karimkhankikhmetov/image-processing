# Environment Configuration for Image Processing Service
# Copy this file to .env and fill in your values

# JWT Configuration
# IMPORTANT: Use a strong random string (at least 256 bits / 32 characters)
# Generate with: openssl rand -base64 64
JWT_SECRET=your-super-secret-jwt-key-minimum-32-chars

# JWT expiration in milliseconds (default: 24 hours = 86400000ms)
JWT_EXPIRATION=86400000

# Database Configuration
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/imageservice_db
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your-secure-database-password

# Storage Configuration
# Use absolute path for production
STORAGE_LOCATION=/var/data/image-service/uploads

# CORS Configuration (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Server Configuration
SERVER_PORT=8080
